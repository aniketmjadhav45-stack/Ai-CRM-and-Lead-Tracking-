generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------
// CORE MULTI-TENANT ENTITIES
// -----------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  contacts           Contact[]
  workflows          Workflow[]
  integrations       Integration[]
  communicationLogs  CommunicationLog[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           String       @default("agent") // admin, agent
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// -----------------------------------------
// CRM & LEAD TRACKING
// -----------------------------------------

model Contact {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  source         String?
  status         String       @default("new") // new, contacted, qualified, lost
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  deals          Deal[]
}

model Deal {
  id          String   @id @default(uuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title       String
  value       Float    @default(0)
  stage       String   @default("lead") // lead, appointment, estimate, won, lost
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------
// OMNIFLOW: NODE-BASED AUTOMATION ENGINE
// -----------------------------------------

model Workflow {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         String       @default("draft") // draft, active, paused
  triggerType    String       // webhook, lead_created, call_ended
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  nodes       WorkflowNode[]
  connections WorkflowConnection[]
  runs        WorkflowRun[]
}

model WorkflowNode {
  id            String   @id @default(uuid())
  workflowId    String
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeType      String   // trigger_webhook, action_sms, action_ai_call, logic_if
  configuration Json     // Flexible JSON for storing node settings (e.g. prompt, phone number)
  positionX     Float    @default(0)
  positionY     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkflowConnection {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode  String   // Reference to WorkflowNode.id
  targetNode  String   // Reference to WorkflowNode.id
  sourceHandle String?
  targetHandle String?
  createdAt   DateTime @default(now())
}

model WorkflowRun {
  id         String   @id @default(uuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status     String   @default("running") // running, completed, failed
  startedAt  DateTime @default(now())
  completedAt DateTime?

  logs       WorkflowLog[]
}

model WorkflowLog {
  id            String      @id @default(uuid())
  workflowRunId String
  run           WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  nodeId        String      // The node that was executed
  status        String      // success, error
  message       String?
  createdAt     DateTime    @default(now())
}

// -----------------------------------------
// UNIFIED COMMUNICATIONS (AI Calling, SMS, WhatsApp)
// -----------------------------------------

model CommunicationLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String       // sms, call, whatsapp, email
  direction      String       // inbound, outbound
  from           String
  to             String
  status         String       // queued, sent, failed, completed
  content        String?      // Body of SMS or transcript of call
  recordingUrl   String?      // Vapi/Twilio recording URL
  createdAt      DateTime     @default(now())
}

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String       // twilio, vapi, hubspot
  apiKey         String       // (Would be encrypted in production)
  config         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
