generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------
// CORE MULTI-TENANT ENTITIES
// -----------------------------------------

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  contacts           Contact[]
  workflows          Workflow[]
  integrations       Integration[]
  communicationLogs  CommunicationLog[]
  adAccounts         AdAccount[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           String       @default("agent") // admin, agent
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// -----------------------------------------
// CRM, LEAD TRACKING & ATTRIBUTION
// -----------------------------------------

model Contact {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Lead Information
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  company        String?
  address        String?
  
  // Lead Source & Marketing Attribution
  source         String?      // Google Ads, Organic, Facebook, Referral
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  adSet          String?
  keyword        String?
  landingPage    String?
  costPerLead    Float?       @default(0)

  // Status & Custom Data
  status         String       @default("new") // new, contacted, qualified, lost
  customFields   Json?        // Flexible storage for CRM sync
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  deals          Deal[]
  communications CommunicationLog[]
}

model Deal {
  id               String   @id @default(uuid())
  contactId        String
  contact          Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Sales Data
  title            String
  value            Float    @default(0)
  revenueGenerated Float    @default(0)
  stage            String   @default("lead") // lead, appointment, estimate, won, lost
  pipeline         String?  @default("default")
  assignedOwnerId  String?  // References User ID
  
  customFields     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// -----------------------------------------
// ADVERTISING & ROI TRACKING
// -----------------------------------------

model AdAccount {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform       String       // google_ads, meta_ads, tiktok_ads
  accountId      String       // The ID on the platform
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  status         String       @default("active") // active, disconnected
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  campaigns      AdCampaign[]
}

model AdCampaign {
  id             String       @id @default(uuid())
  adAccountId    String
  adAccount      AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  platformId     String       // Campaign ID from the ad network
  name           String
  status         String
  totalSpend     Float        @default(0)
  clicks         Int          @default(0)
  impressions    Int          @default(0)
  leadsGenerated Int          @default(0)
  revenue        Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// -----------------------------------------
// INTEGRATIONS & OAUTH TOKENS
// -----------------------------------------

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String       // hubspot, salesforce, twilio, sendgrid, gmail, outlook
  type           String       // crm, email, sms, voice
  
  // Credentials (Should be encrypted in production logic before saving)
  apiKey         String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  
  config         Json?        // webhook URLs, connected pipeline IDs, etc.
  status         String       @default("active") // active, error, disconnected
  errorMessage   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// -----------------------------------------
// OMNIFLOW: NODE-BASED AUTOMATION ENGINE
// -----------------------------------------

model Workflow {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         String       @default("draft") // draft, active, paused
  triggerType    String       // webhook, lead_created, call_ended
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  nodes       WorkflowNode[]
  connections WorkflowConnection[]
  runs        WorkflowRun[]
}

model WorkflowNode {
  id            String   @id @default(uuid())
  workflowId    String
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeType      String   // trigger_webhook, action_sms, action_email, action_ai_call, logic_if
  configuration Json     // Storing node settings
  positionX     Float    @default(0)
  positionY     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WorkflowConnection {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode  String   
  targetNode  String   
  sourceHandle String?
  targetHandle String?
  createdAt   DateTime @default(now())
}

model WorkflowRun {
  id         String   @id @default(uuid())
  workflowId String
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status     String   @default("running") // running, completed, failed
  startedAt  DateTime @default(now())
  completedAt DateTime?

  logs       WorkflowLog[]
}

model WorkflowLog {
  id            String      @id @default(uuid())
  workflowRunId String
  run           WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  nodeId        String      
  status        String      // success, error
  message       String?
  createdAt     DateTime    @default(now())
}

// -----------------------------------------
// UNIFIED COMMUNICATIONS & TIMELINE
// -----------------------------------------

model CommunicationLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  type           String       // sms, call, whatsapp, email, note, ticket
  direction      String       // inbound, outbound
  from           String
  to             String
  status         String       // queued, sent, failed, completed
  
  // Payload Data
  subject        String?      // For emails
  content        String?      // Body of SMS/Email or transcript of call/note
  recordingUrl   String?      // Vapi/Twilio recording URL
  attachments    Json?        // Array of attachment URLs
  
  createdAt      DateTime     @default(now())
}
